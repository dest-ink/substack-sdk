# Environment variables for running E2E tests
# Copy this file to .env and fill in your actual values

# Required: Your substack.sid cookie value (from browser after logging in)
SUBSTACK_SID=your-sid-here

# Required: Your substack.lli cookie value (from browser after logging in)
SUBSTACK_LLI=your-lli-here

# Required: Your Substack publication URL
# Example: https://yourname.substack.com
PUBLICATION_URL=https://yoursite.substack.com
